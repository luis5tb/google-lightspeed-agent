{
  "displayName": "Lightspeed — Agent Operations",
  "mosaicLayout": {
    "columns": 48,
    "tiles": [
      {
        "xPos": 0,
        "yPos": 0,
        "width": 48,
        "height": 16,
        "widget": {
          "title": "Tool Calls by Name",
          "timeSeriesTable": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (tool_name) (last_over_time(tool_calls_by_name_total[2m]))"
                }
              }
            ],
            "metricVisualization": "BAR",
            "columnSettings": [
              { "column": "tool_name", "displayName": "Tool", "visible": true },
              { "column": "value", "displayName": "Count", "visible": true }
            ]
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 16,
        "width": 48,
        "height": 16,
        "widget": {
          "title": "Requests Over Time",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(delta(request_count[1d]))"
                },
                "plotType": "LINE",
                "legendTemplate": "Requests"
              }
            ],
            "yAxis": {
              "label": "Requests"
            },
            "chartOptions": {
              "mode": "COLOR"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 32,
        "width": 48,
        "height": 16,
        "widget": {
          "title": "Token Usage Over Time",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(delta(input_tokens[1d]))"
                },
                "plotType": "LINE",
                "legendTemplate": "Input Tokens"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(delta(output_tokens[1d]))"
                },
                "plotType": "LINE",
                "legendTemplate": "Output Tokens"
              }
            ],
            "yAxis": {
              "label": "Tokens"
            },
            "chartOptions": {
              "mode": "COLOR"
            }
          }
        }
      }
    ]
  },
  "dashboardFilters": [
    {
      "labelKey": "service_name",
      "filterType": "METRIC_LABEL",
      "stringValue": "",
      "valueType": "STRING"
    }
  ],
  "labels": {
    "lightspeed-agent": ""
  }
}
