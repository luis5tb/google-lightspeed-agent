{
  "displayName": "Lightspeed — Marketplace",
  "mosaicLayout": {
    "columns": 48,
    "tiles": [
      {
        "xPos": 0,
        "yPos": 0,
        "width": 24,
        "height": 16,
        "widget": {
          "title": "Subscriptions by State",
          "timeSeriesTable": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (account_id) (subscriptions_count{state=\"active\"})"
                }
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (account_id) (subscriptions_count{state=\"cancelled\"})"
                }
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (account_id) (subscriptions_count{state=\"pending_approval\"})"
                }
              }
            ],
            "metricVisualization": "NUMBER",
            "columnSettings": [
              { "column": "Name", "visible": false },
              { "column": "account_id", "displayName": "Account", "visible": true },
              { "column": "value", "displayName": "Active", "visible": true },
              { "column": "value-1", "displayName": "Cancelled", "visible": true },
              { "column": "value-2", "displayName": "Pending", "visible": true }
            ]
          }
        }
      },
      {
        "xPos": 24,
        "yPos": 0,
        "width": 24,
        "height": 16,
        "widget": {
          "title": "Active DCR Clients",
          "timeSeriesTable": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (account_id) (dcr_clients_active)"
                }
              }
            ],
            "metricVisualization": "BAR",
            "columnSettings": [
              { "column": "account_id", "displayName": "Account", "visible": true },
              { "column": "value", "displayName": "Clients", "visible": true }
            ]
          }
        }
      }
    ]
  },
  "dashboardFilters": [
    {
      "labelKey": "service_name",
      "filterType": "METRIC_LABEL",
      "stringValue": "",
      "valueType": "STRING"
    }
  ],
  "labels": {
    "lightspeed-agent": ""
  }
}
