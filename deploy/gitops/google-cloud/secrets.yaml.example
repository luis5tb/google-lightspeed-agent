# =============================================================================
# Secrets required for the Google Cloud deployment
# =============================================================================
#
# The deploy Job needs a GCP service account key to authenticate with gcloud
# and submit Cloud Build pipelines. Create the bootstrap secret:
#
#   oc create secret generic gcp-sa-bootstrap \
#     --from-file=gcp-service-account-key=sa-key.json \
#     -n <namespace>
#
# Or use the setup script (creates the SA, grants roles, and creates the secret):
#   export GOOGLE_CLOUD_PROJECT=my-project-id
#   bash deploy/gitops/setup/setup-gcp-sa.sh
#
# The following secrets must exist in GCP Secret Manager (created by setup.sh).
# Cloud Run services read these directly from GCP SM at runtime:
#   - redhat-sso-client-id
#   - redhat-sso-client-secret
#   - database-url
#   - session-database-url
#   - gma-client-id
#   - gma-client-secret
#   - dcr-encryption-key
#   - rate-limit-redis-url
#   - redis-ca-cert
#   - otel-collector-config
#   - gcp-service-account-key
#
# =============================================================================
#
# Optional: for private git repositories, create a token secret:
#   oc create secret generic git-credentials \
#     --from-literal=token=<GITHUB_PAT> \
#     -n <namespace>
#
# Then set in your values override:
#   deploy:
#     gitTokenSecret: git-credentials
