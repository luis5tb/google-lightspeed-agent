# =============================================================================
# Bootstrap GCP credentials for External Secrets Operator (ESO)
# =============================================================================
#
# ESO needs a GCP service account key to authenticate to GCP Secret Manager.
# This is a one-time bootstrap step — ESO then manages all other secrets.
#
# Create the bootstrap secret:
#   oc create secret generic gcp-sa-bootstrap \
#     --from-file=gcp-service-account-key=sa-key.json \
#     -n <namespace>
#
# Required GCP SA roles:
#   - roles/secretmanager.secretAccessor (read secrets from GCP SM)
#   - roles/cloudbuild.builds.editor (submit Cloud Build)
#   - roles/iam.serviceAccountUser (impersonate the Cloud Run SA)
#
# The following secrets must exist in GCP Secret Manager (created by setup.sh):
#   - redhat-sso-client-id
#   - redhat-sso-client-secret
#   - database-url
#   - session-database-url
#   - gma-client-id
#   - gma-client-secret
#   - dcr-encryption-key
#   - rate-limit-redis-url
#   - redis-ca-cert
#   - otel-collector-config
#   - gcp-service-account-key
#
# =============================================================================
#
# Optional: for private git repositories, create a token secret:
#   oc create secret generic git-credentials \
#     --from-literal=token=<GITHUB_PAT> \
#     -n <namespace>
#
# Then set in your values override:
#   deploy:
#     gitTokenSecret: git-credentials
